{
  "name": "fida/pilot",
  "description": "Laravel CRUD Generator package",
  "type": "library",
  "license": "MIT",

  "keywords": [
    "laravel",
    "crud",
    "generator"
  ],

  "autoload": {
    "psr-4": {
      "Fida\\Crud\\": "src/"
    }
  },

  "extra": {
    "laravel": {
      "providers": [
        "Fida\\Crud\\PilotServiceProvider"
      ]
    }
  },

  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0"
  }
}